# Jumpgate server configuration
# Copy to jumpgate.yaml and customize.

# SQLite database path
# db: data/jumpgate.db

# Listen address
# addr: :8080

# Enable admin authorization check (reverse proxy headers)
# auth: true

# Artificial delay in seconds for non-static requests (0 = disabled)
# slow: 0

# Demo mode — in-memory per-session databases loaded from a data file
# demo:
#   enabled: false
#   source: bookmarks.yaml.example
#
#   # Explicit disable mode
#   # disable_proxy_headers: true
#
#   # Allowlist mode: IPs and CIDRs allowed to contribute
#   # X-Forwarded-For values when demo mode runs behind a proxy or CDN.
#   # allowed_proxies:
#   #   - "127.0.0.1"
#   #   - "10.0.0.0/8"
#   #   - "203.0.113.10"

# JSON API for agents, scripts, and automation
# API is disabled when both token lists are empty.
# api:
#   swagger: true
#   tokens:
#     read-write:
#       - "rw-secret-here"
#     read-only:
#       - "ro-secret-here"

# MCP server (Streamable HTTP at /mcp, uses api.tokens for auth)
# Requires api.tokens to be configured.
# mcp:
#   enabled: false
